# Auto detect text files and perform LF normalization
* text=auto
backend/website_data.json filter=lfs diff=lfs merge=lfs -text
backend/faiss_store/index.faiss filter=lfs diff=lfs merge=lfs -text
backend/faiss_store/index.pkl filter=lfs diff=lfs merge=lfs -text
*.json filter=lfs diff=lfs merge=lfs -text
*.faiss filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.json !text !filter !merge !diff
*.faiss !text !filter !merge !diff
*.pkl !text !filter !merge !diff
*.bin !text !filter !merge !diff
*.h5 !text !filter !merge !diff
*.zip !text !filter !merge !diff
website_data.json filter=lfs diff=lfs merge=lfs -text
backend/faiss_store/** filter=lfs diff=lfs merge=lfs -text
**/index.faiss filter=lfs diff=lfs merge=lfs -text
**/index.pkl filter=lfs diff=lfs merge=lfs -text
**/chroma.sqlite3 filter=lfs diff=lfs merge=lfs -text
**/*.bin filter=lfs diff=lfs merge=lfs -text
